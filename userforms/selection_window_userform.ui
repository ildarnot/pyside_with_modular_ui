      <property name="styleSheet">
       <string notr="true">QToolButton {
    background-color: rgba(240, 240, 240, 1.0); /* Светло‑серый фон */
    color: #444444; /* Тёмно‑серый текст */
    border-radius: 8px;
    border: 2px solid #d0d0d0; /* Серая граница */
    font-weight: normal;
}

/* ЧЁТКИЙ ЭФФЕКТ ПРИ НАВЕДЕНИИ НА НЕАКТИВНУЮ КНОПКУ */
QToolButton:hover {
    background-color: rgba(220, 220, 220, 1.0); /* Заметно темнее */
    border: 2px solid #b0b0b0; /* Темнее граница */
}

QToolButton:pressed {
    background-color: rgba(200, 200, 200, 1.0); /* Ещё темнее при нажатии */
    border: 2px solid #909090;
    margin: 1px; /* Небольшой сдвиг для эффекта нажатия */
}

/* Состояние CHECKED — прежние цвета */
QToolButton:checked {
    background-color: transparent;
    color: black;
    border: 2px solid rgba(64, 250, 64, 0.5); /* Более насыщенный голубой */
}

QToolButton:checked:hover {
    background-color: rgba(64, 250, 64, 0.05);
}

QToolButton:checked:pressed {
    background-color: rgba(64, 250, 64, 0.1);
}</string>
